{
  "serial": {
    "port": "/dev/ttyUSB0",
    "baudrate": 9600,
    "bytesize": 8,
    "parity": "N",
    "stopbits": 1,
    "timeout_ms": 1000,
    "address_bits": 8
  },
  "request": {
    "address": 96,
    "parameter": "rEAd",
    "protocol_format": "float32"
  },
  "retries": 3,
  "inter_request_delay_ms": 15,
  "poll_interval_ms": 1000,
  "cycles": 5
}
